# Example values - replace with your actual values
organization_id       = "o-1234567890"
management_account_id = "123456789012"
organization_root_id  = "r-abcd"
display_name          = "My Organization"

# SCA configuration
# Set to true if you have AWS IAM Identity Center configured
sca_sso_enable = false
# sca_sso_region is only required when sca_sso_enable = true
# sca_sso_region = "us-east-1"

# Secrets Hub configuration - comma-separated regions
# Adjust to match your operational regions
secrets_hub_regions = "us-east-1,us-west-2"

